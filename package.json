{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-control.js",
    "dev:web": "node scripts/banner.js vite",
    "dev:desktop-web": "node scripts/banner.js vite --mode electron --port 5174",
    "dev:desktop": "node scripts/banner.js wait-on tcp:127.0.0.1:5174 && node scripts/banner.js electron .",
    "dev:backend": "node scripts/banner.js cargo run --manifest-path backend/Cargo.toml --target x86_64-pc-windows-gnu",
    "start": "electron .",
    "build": "node scripts/clean-dist.js && npm run build:backend && npm run build:desktop-web && npm run build:desktop",
    "build:web": "vite build",
    "build:desktop-web": "vite build --mode electron",
    "build:desktop": "node scripts/build-desktop.mjs dir",
    "build:portable": "node scripts/clean-dist.js && npm run build:backend && npm run build:desktop-web && node scripts/build-desktop.mjs portable",
    "build:installer": "node scripts/clean-dist.js && npm run build:backend && npm run build:desktop-web && node scripts/build-desktop.mjs installer",
    "build:backend": "cargo build --release --manifest-path backend/Cargo.toml --target x86_64-pc-windows-gnu",
    "preview:web": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "prismjs": "^1.30.0",
    "re-resizable": "6.11.2",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-hook-form": "7.55.0",
    "react-markdown": "9.0.3",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-simple-code-editor": "^0.14.1",
    "react-slick": "0.31.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "2.15.2",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/prismjs": "^1.26.6",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12",
    "tailwindcss": "4.1.12",
    "vite": "6.3.5",
    "vite-plugin-singlefile": "^2.3.3",
    "wait-on": "^8.0.5"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "com.venture.app",
    "productName": "Venture",
    "asar": true,
    "asarUnpack": [
      "dist/web/**/*"
    ],

    "files": [
      "dist/web/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "!backend/**/*",
      "!src/**/*",
      "!scripts/**/*",
      "!.trae/**/*",
      "!.cursor/**/*",
      "!*.md",
      "!*.log",
      "!*.yaml",
      "!*.yml",
      "!*.nsh"
    ],

    "extraResources": [
      {
        "from": "backend/target/x86_64-pc-windows-gnu/release/venture-backend.exe",
        "to": "venture-backend.exe"
      }
    ],

    "directories": {
      "buildResources": "build",
      "output": "dist"
    },

    "compression": "maximum",

    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Venture-Setup-${version}.exe"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Venture",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "uninstallDisplayName": "Venture",
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeader": null,
      "installerSidebar": null,
      "differentialPackage": false,
      "include": "build/installer.nsh"
    }
  }
}
